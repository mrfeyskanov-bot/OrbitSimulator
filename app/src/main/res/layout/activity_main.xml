<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌌 ORBIT SIMULATOR"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:padding="16dp"
        android:background="#16213e"
        android:layout_margin="8dp"/>

    <com.example.orbitsimulator.SpaceView
        android:id="@+id/spaceView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="8dp"
        android:background="#000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213e"
        android:padding="16dp"
        android:layout_margin="8dp">

        <!-- Количество планет -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪐 Планет:"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btnMinusPlanet"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="24sp"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvPlanetCount"
                android:layout_width="60dp"
                android:layout_height="48dp"
                android:text="0"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnPlusPlanet"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="24sp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <!-- Кнопки управления -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnSimulate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="▶ СТАРТ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="⏹ СТОП"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#F44336"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Скорость симуляции -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Скорость симуляции"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/speedSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="20"
                android:thumbTint="#FFD700"
                android:progressTint="#4CAF50"/>

            <TextView
                android:id="@+id/tvSpeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.5x"
                android:textSize="12sp"
                android:textColor="#FFD700"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Масса Солнца -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ Масса Солнца"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnSunMassMinus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:textSize="20sp"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvSunMass"
                    android:layout_width="80dp"
                    android:layout_height="40dp"
                    android:text="1000"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnSunMassPlus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Кнопка выхода в меню -->
        <Button
            android:id="@+id/btnExitToMenu"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="◀ ВЫХОД В МЕНЮ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#607D8B"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Нажми + чтобы добавить планету"
            android:textSize="11sp"
            android:textColor="#FFD700"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:padding="6dp"
            android:background="#0f3460"/>

    </LinearLayout>

</LinearLayout>