<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ НАСТРОЙКИ"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:gravity="center"
        android:padding="16dp"
        android:background="#16213e"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213e"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Гравитационная постоянная (G)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnGMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="24sp"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvGValue"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:text="0.8"
                android:textSize="18sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnGPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="24sp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(0.1 - 2.0)"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📖 О ПРОГРАММЕ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:background="#16213e"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Orbit Simulator — 2D гравитационный симулятор.\n\nЗаконы физики:\n• F = G × M × m / r²\n• a = F / m\n\nВозможности:\n• Добавление/удаление планет\n• Редактирование параметров (долгое нажатие)\n• Изменение массы Солнца\n• Регулировка скорости симуляции\n• Планеты влияют друг на друга\n\n© 2024 Orbit Simulator"
        android:textSize="12sp"
        android:textColor="#CCCCCC"
        android:background="#16213e"
        android:padding="12dp"
        android:lineSpacingExtra="4dp" />

    <Button
        android:id="@+id/btnBackToMenu"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="◀ НАЗАД В МЕНЮ"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="16dp" />

</LinearLayout>