<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ПОЛОЖЕНИЕ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X координата"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

                <EditText
                    android:id="@+id/etX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="0-1000"
                    android:background="@android:drawable/editbox_background"
                    android:padding="10dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Y координата"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

                <EditText
                    android:id="@+id/etY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="0-1000"
                    android:background="@android:drawable/editbox_background"
                    android:padding="10dp"/>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ ФИЗИЧЕСКИЕ ПАРАМЕТРЫ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Масса планеты"
            android:textSize="12sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etMass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="5-20"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Скорость X (Vx)"
            android:textSize="12sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etVx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="-5 до 5"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Скорость Y (Vy)"
            android:textSize="12sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etVy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="-5 до 5"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 Для круговой орбиты:\n• Скорость должна быть перпендикулярна радиусу\n• V ≈ 2.0 при расстоянии ≈200px"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
</ScrollView>